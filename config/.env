# ============================================================================
# TRUSTLINK ENVIRONMENT CONFIGURATION
# Version: 1.0 | Production Ready | March 2026
# 
# Instructions:
# 1. Copy this file to .env
# 2. Update values for your environment
# 3. NEVER commit .env to version control
# ============================================================================

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME="TrustLink"
APP_ENV="development"           # development, staging, production
APP_DEBUG=true                  # Set to false in production
APP_URL="http://localhost/trustfiles"     
APP_TIMEZONE="Africa/Nairobi"

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================
DB_DRIVER="pgsql"
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="trustlink"
DB_USER="postgres"
DB_PASS="Nasiuma.12?"
DB_CHARSET="utf8"

# ============================================================================
# DATABASE POOLING (Optional - for production)
# ============================================================================
DB_POOL_SIZE="10"
DB_IDLE_TIMEOUT="300"

# ============================================================================
# SESSION CONFIGURATION
# ============================================================================
SESSION_NAME="trustlink_session"
SESSION_LIFETIME="7200"         # 2 hours in seconds
SESSION_PATH="/"
SESSION_DOMAIN=               
SESSION_SECURE=false            # Set to true in production with HTTPS
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE="Lax"         # Strict, Lax, None

# ============================================================================
# SECURITY
# ============================================================================
# Password hashing cost (4-31, higher = more secure but slower)
PASSWORD_HASH_COST="12"

# CSRF Protection
CSRF_TOKEN_NAME="trustlink_csrf"
CSRF_TOKEN_LIFETIME="7200"

# Rate Limiting (requests per minute)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS="60"

# ============================================================================
# FILE UPLOADS
# ============================================================================
UPLOAD_MAX_SIZE="5242880"       # 5MB in bytes
UPLOAD_ALLOWED_TYPES="image/jpeg,image/png,image/webp"
UPLOAD_PATH="assets/images/uploads"

# ============================================================================
# MAIL CONFIGURATION (Reserved for future)
# ============================================================================
MAIL_DRIVER="smtp"
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_USERNAME=""
MAIL_PASSWORD=""
MAIL_ENCRYPTION="tls"
MAIL_FROM_ADDRESS="noreply@trustlink.ke"
MAIL_FROM_NAME="TrustLink"

# ============================================================================
# SMS CONFIGURATION (Reserved for future - Africa's Talking, etc.)
# ============================================================================
SMS_DRIVER="africastalking"
SMS_API_KEY=""
SMS_USERNAME=""
SMS_SENDER_ID="TrustLink"

# ============================================================================
# PAYMENT GATEWAYS (Reserved for future)
# ============================================================================
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_PASSKEY=""
MPESA_SHORTCODE=""

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL="debug"               # debug, info, warning, error
LOG_PATH="logs/error.log"
LOG_MAX_FILES="30"              # Days to keep logs

# ============================================================================
# API RATE LIMITING
# ============================================================================
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS="100"   # Requests per minute per IP
API_RATE_LIMIT_WINDOW="60"      # Window in seconds

# ============================================================================
# CACHE (Reserved for future)
# ============================================================================
CACHE_DRIVER="file"             # file, redis, memcached
CACHE_PATH="cache/"
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD=""